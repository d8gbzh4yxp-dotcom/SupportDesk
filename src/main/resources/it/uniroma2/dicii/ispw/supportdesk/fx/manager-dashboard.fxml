<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.uniroma2.dicii.ispw.supportdesk.boundary.javafx.ManagerDashboardControllerGrafico"
            style="-fx-background-color: #ECEFF1;">

    <!-- ── HEADER ──────────────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #1A237E; -fx-padding: 14 20;">
            <Label text="SupportDesk"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Label text="/ Manager"
                   style="-fx-text-fill: #90CAF9; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel"
                   style="-fx-text-fill: #E3F2FD; -fx-font-size: 13px;"/>
            <Button text="Logout" onAction="#onLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #90CAF9;
                           -fx-border-color: #90CAF9; -fx-border-radius: 4; -fx-cursor: hand; -fx-padding: 5 12;"/>
        </HBox>
    </top>

    <!-- ── CONTENUTO ───────────────────────────────────────────── -->
    <center>
        <VBox spacing="16">
            <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>

            <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

                <!-- TAB 1: Tutti i Ticket -->
                <Tab text="Tutti i Ticket">
                    <VBox spacing="12">
                        <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Panoramica Ticket"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1A237E;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Aggiorna" onAction="#onRefreshAll"
                                    style="-fx-background-color: #E3F2FD; -fx-text-fill: #1565C0;
                                           -fx-border-color: #90CAF9; -fx-border-radius: 4; -fx-cursor: hand; -fx-padding: 5 10;"/>
                        </HBox>

                        <TableView fx:id="allTicketsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId"       text="ID"        prefWidth="50"/>
                                <TableColumn fx:id="colTitle"    text="Titolo"    prefWidth="220"/>
                                <TableColumn fx:id="colCategory" text="Categoria" prefWidth="110"/>
                                <TableColumn fx:id="colPriority" text="Priorità"  prefWidth="90"/>
                                <TableColumn fx:id="colStatus"   text="Stato"     prefWidth="120"/>
                                <TableColumn fx:id="colTech"     text="Tecnico"   prefWidth="140"/>
                                <TableColumn fx:id="colSla"      text="Scadenza SLA" prefWidth="140"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- TAB 2: Violazioni SLA -->
                <Tab text="Violazioni SLA">
                    <VBox spacing="12">
                        <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>

                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Ticket in scadenza o violati"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #B71C1C;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Verifica SLA" onAction="#onCheckSla"
                                    style="-fx-background-color: #C62828; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-border-radius: 4; -fx-cursor: hand; -fx-padding: 5 12;"/>
                        </HBox>

                        <TableView fx:id="slaTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="slaColId"       text="ID"        prefWidth="50"/>
                                <TableColumn fx:id="slaColTitle"    text="Titolo"    prefWidth="250"/>
                                <TableColumn fx:id="slaColPriority" text="Priorità"  prefWidth="100"/>
                                <TableColumn fx:id="slaColStatus"   text="Stato"     prefWidth="120"/>
                                <TableColumn fx:id="slaColSla"      text="Scadenza SLA" prefWidth="160"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <!-- TAB 3: Ticket Correlati -->
                <Tab text="Ticket Correlati">
                    <VBox spacing="12">
                        <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>

                        <Label text="Cerca ticket correlati per ID"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1A237E;"/>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <TextField fx:id="correlationIdField"
                                       promptText="Inserisci ID ticket..."
                                       prefWidth="200"
                                       style="-fx-padding: 8; -fx-background-radius: 4;
                                              -fx-border-color: #E0E0E0; -fx-border-radius: 4;"/>
                            <Button text="Cerca correlati" onAction="#onFindCorrelated"
                                    style="-fx-background-color: #1565C0; -fx-text-fill: white;
                                           -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 4; -fx-cursor: hand;"/>
                            <Label fx:id="correlationErrorLabel" text=""
                                   style="-fx-text-fill: #C62828; -fx-font-size: 11px;"/>
                        </HBox>

                        <TableView fx:id="correlatedTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="corrColId"       text="ID"        prefWidth="50"/>
                                <TableColumn fx:id="corrColTitle"    text="Titolo"    prefWidth="250"/>
                                <TableColumn fx:id="corrColCategory" text="Categoria" prefWidth="110"/>
                                <TableColumn fx:id="corrColStatus"   text="Stato"     prefWidth="120"/>
                                <TableColumn fx:id="corrColSla"      text="Scadenza SLA" prefWidth="160"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

            </TabPane>

            <!-- DETAIL PANEL condiviso: si popola al click su qualsiasi riga -->
            <VBox fx:id="detailPanel" visible="false" managed="false" spacing="6"
                  style="-fx-background-color: #E3F2FD;
                         -fx-background-radius: 6;
                         -fx-border-color: #90CAF9;
                         -fx-border-radius: 6;
                         -fx-border-width: 1;">
                <padding><Insets top="12" bottom="12" left="16" right="16"/></padding>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Dettaglio Ticket"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1A237E;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#onCloseDetail"
                            style="-fx-background-color: transparent; -fx-text-fill: #616161;
                                   -fx-cursor: hand; -fx-font-size: 13px;"/>
                </HBox>
                <Separator/>
                <GridPane hgap="20" vgap="5">
                    <Label text="ID:"          GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #455A64;"/>
                    <Label fx:id="detailId"    GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Titolo:"      GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #455A64;"/>
                    <Label fx:id="detailTitle" GridPane.rowIndex="1" GridPane.columnIndex="1" wrapText="true"/>
                    <Label text="Descrizione:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #455A64;"/>
                    <Label fx:id="detailDescription" GridPane.rowIndex="2" GridPane.columnIndex="1" wrapText="true" maxWidth="500"/>
                    <Label text="Categoria:"   GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #455A64;"/>
                    <Label fx:id="detailCategory" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    <Label text="Priorità:"    GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #455A64;"/>
                    <Label fx:id="detailPriority" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    <Label text="Stato:"       GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #455A64;"/>
                    <Label fx:id="detailStatus" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                    <Label text="Aperto il:"   GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #455A64;"/>
                    <Label fx:id="detailDataApertura" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                    <Label text="Scadenza SLA:" GridPane.rowIndex="7" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #455A64;"/>
                    <Label fx:id="detailSla"   GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                    <Label text="Tecnico:"     GridPane.rowIndex="8" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #455A64;"/>
                    <Label fx:id="detailTechnician" GridPane.rowIndex="8" GridPane.columnIndex="1"/>
                </GridPane>
            </VBox>

        </VBox>
    </center>

</BorderPane>
